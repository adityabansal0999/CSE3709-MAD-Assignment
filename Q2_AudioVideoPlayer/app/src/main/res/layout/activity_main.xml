<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        xmlns:tools="http://schemas.android.com/tools"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        tools:context=".MainActivity">

        <!-- App title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:text="Audio / Video Player"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/blue_primary" />

        <!-- ===== AUDIO SECTION ===== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Audio Player"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_open_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Audio File"
            android:backgroundTint="@color/blue_primary"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txt_file_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No file selected"
            android:textSize="14sp"
            android:padding="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/txt_audio_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Ready"
            android:textSize="14sp"
            android:textStyle="italic"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <SeekBar
            android:id="@+id/seekbar_audio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_audio_play"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Play"
                android:drawableStart="@android:drawable/ic_media_play"
                android:backgroundTint="@color/green_play"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_audio_pause"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Pause"
                android:drawableStart="@android:drawable/ic_media_pause"
                android:backgroundTint="@color/orange_pause"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_audio_stop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Stop"
                android:drawableStart="@android:drawable/ic_menu_close_clear_cancel"
                android:backgroundTint="@color/red_stop"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_audio_restart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Restart"
                android:drawableStart="@android:drawable/ic_menu_revert"
                android:backgroundTint="@color/blue_light"
                android:textSize="12sp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/blue_primary"
            android:layout_marginBottom="20dp" />

        <!-- ===== VIDEO SECTION ===== -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Video Player (Stream from URL)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/edit_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter video URL"
            android:inputType="textUri"
            android:padding="12dp"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_open_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open URL"
            android:backgroundTint="@color/blue_primary"
            android:drawableStart="@android:drawable/ic_menu_share"
            android:layout_marginBottom="8dp" />

        <VideoView
            android:id="@+id/video_view"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txt_video_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Ready"
            android:textSize="14sp"
            android:textStyle="italic"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_video_play"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Play"
                android:drawableStart="@android:drawable/ic_media_play"
                android:backgroundTint="@color/green_play"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_video_pause"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Pause"
                android:drawableStart="@android:drawable/ic_media_pause"
                android:backgroundTint="@color/orange_pause"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_video_stop"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Stop"
                android:drawableStart="@android:drawable/ic_menu_close_clear_cancel"
                android:backgroundTint="@color/red_stop"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_video_restart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_margin="2dp"
                android:text="Restart"
                android:drawableStart="@android:drawable/ic_menu_revert"
                android:backgroundTint="@color/blue_light"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>